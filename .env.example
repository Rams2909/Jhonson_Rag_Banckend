# PostgreSQL / pgvector
POSTGRES_DSN=postgresql+psycopg://graphrag:graphrag@localhost:5432/graphrag

# FalkorDB (Redis-compatible)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=graphrag

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval
TOP_K_DEFAULT=10
BM25_TOP_K=20
VECTOR_TOP_K=20
GRAPH_TOP_K=20
RERANK_TOP_K=10
